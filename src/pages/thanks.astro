---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Got it! — Software Joe" description="Thanks for reaching out." noindex={true}>
  <main>
    <header class="hero">
      <div class="eyebrow">Message received</div>
      <h1>Got it! <span class="accent">Talk soon.</span></h1>
      <p class="subtitle">Thanks for reaching out — I read everything personally and I'll get back to you fast.</p>
      <div class="hero-cta">
        <a href="/" class="cta-button">Back to home</a>
      </div>
    </header>
  </main>
</BaseLayout>
