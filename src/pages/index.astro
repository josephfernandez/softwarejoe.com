---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Booking from '../components/Booking.astro';

const title = 'Software Joe — Custom Software & AI Solutions for Business';
const description =
  'Senior software engineer building custom software and AI solutions that make businesses faster, leaner, and more profitable. Book a free consultation.';
---

<BaseLayout title={title} description={description} image="/og/home.png">
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Software Joe",
    "description": "Custom software and AI solutions that make businesses faster, leaner, and more profitable.",
    "url": "https://softwarejoe.com",
    "image": "https://softwarejoe.com/og-image.png",
    "email": "joe@softwarejoe.com",
    "areaServed": "Worldwide",
    "priceRange": "$$",
    "founder": {
      "@type": "Person",
      "name": "Joe Fernandez",
      "alternateName": "Software Joe",
      "jobTitle": "Senior Software Engineer & Consultant",
      "sameAs": ["https://x.com/CryptLFG", "https://linkedin.com/in/jfernandez1988"]
    },
    "knowsAbout": ["Software Development", "Custom Software", "Web Applications", "Workflow Automation", "Systems Integration", "Artificial Intelligence", "AI Agents", "Business Productivity"],
    "makesOffer": [
      { "@type": "Offer", "name": "Software & AI Strategy Consultation" },
      { "@type": "Offer", "name": "Custom Software & AI Builds" },
      { "@type": "Offer", "name": "Systems & Products" }
    ]
  })} />

  <Nav />

  <main id="top">
    <!-- Hero -->
    <header class="hero">
      <div class="eyebrow">Software that moves your business</div>
      <h1>I build software that makes your business <span class="accent">faster, leaner, and more profitable</span> — with AI where it gives you an edge.</h1>
      <p class="subtitle">
        I'm Joe — a senior software engineer. I build the right solution for the problem:
        well-built, dependable software, with AI layered in when it gives you a real edge.
        For founders, small businesses, and enterprises alike.
      </p>
      <div class="hero-cta">
        <a href="#book" class="cta-button" data-cta="hero_book">Book a free consultation</a>
        <a href="#services" class="cta-secondary" data-cta="hero_services">See how I help &rarr;</a>
      </div>
      <div class="trust-row">
        <span>Trusted approach for:</span>
        <span class="chip">Solo founders</span>
        <span class="chip">Small business</span>
        <span class="chip">Mid-market</span>
        <span class="chip">Enterprise</span>
      </div>
    </header>

    <!-- Value Props -->
    <section class="value-grid">
      <div class="value-card">
        <div class="value-icon">&#9889;</div>
        <h2>More productive</h2>
        <p>Kill the busywork and the bottlenecks. Custom tools and automation — AI-powered when it helps — that hand your team their time back.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">&#9881;</div>
        <h2>More efficient</h2>
        <p>Cut cost and friction. Better software, tighter workflows, and the right systems — so your team ships more with less.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">&#128200;</div>
        <h2>More profitable</h2>
        <p>Technology tied to the bottom line — not a science project. Every build maps to a real outcome you can measure.</p>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="section">
      <div class="section-head">
        <div class="card-label">What I offer</div>
        <h2>Start with a conversation. Scale into a system.</h2>
        <p class="section-sub">Most engagements start with a consultation, then grow into hands-on builds and repeatable systems.</p>
      </div>

      <div class="service-list">
        <div class="card featured">
          <div class="card-label">Step 1 &middot; Start here</div>
          <h2>Strategy Consultation</h2>
          <p>A focused session to find where better software — and AI, where it fits — actually pays off in your business. You leave with a clear, prioritized action plan. Looking specifically for <a href="/ai-consulting-for-small-business/">AI consulting for small business</a>? Start there.</p>
          <ul class="feature-list">
            <li>Audit of your workflows &amp; biggest time sinks</li>
            <li>Opportunities ranked by real ROI</li>
            <li>Straight tech recommendations (no vendor fluff)</li>
            <li>A plan you can act on with or without me</li>
          </ul>
          <a href="#book" class="cta-button" data-cta="services_book">Book a free consultation</a>
        </div>

        <div class="card">
          <div class="card-label">Step 2 &middot; Build</div>
          <h2>Custom Software &amp; AI</h2>
          <p>I build the thing. Web apps, internal tools, automations, integrations — and AI features layered in when they earn their place. See <a href="/custom-software-development/">custom software development</a>.</p>
          <ul class="feature-list">
            <li>Web &amp; internal apps, dashboards, tools</li>
            <li>Workflow automation &amp; integrations</li>
            <li>AI agents, assistants &amp; data pipelines</li>
            <li>Built right, documented, and handed off</li>
          </ul>
        </div>

        <div class="card">
          <div class="card-label">Step 3 &middot; Scale</div>
          <h2>Systems &amp; Products</h2>
          <p>Repeatable systems and productized tools so the gains compound — not just a one-off win that fades.</p>
          <ul class="feature-list">
            <li>Reusable playbooks &amp; templates</li>
            <li>Team training &amp; enablement</li>
            <li>Ongoing optimization &amp; support</li>
            <li>Productized tools for your niche</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="section">
      <div class="section-head">
        <div class="card-label">How it works</div>
        <h2>Simple, fast, no fluff.</h2>
      </div>
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">01</div>
          <h3>Book a call</h3>
          <p>Tell me what's slow, manual, or expensive. We figure out the right way to fix it.</p>
        </div>
        <div class="process-step">
          <div class="step-num">02</div>
          <h3>Get a plan</h3>
          <p>You get a clear, prioritized roadmap — the highest-ROI moves first.</p>
        </div>
        <div class="process-step">
          <div class="step-num">03</div>
          <h3>Ship &amp; profit</h3>
          <p>I build it (or guide your team), and you start seeing the results.</p>
        </div>
      </div>
    </section>

    <!-- Contact / Book -->
    <Booking />
  </main>

  <Footer />
</BaseLayout>
